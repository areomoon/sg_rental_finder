# ── Gmail (發送端：App Password SMTP) ─────────────────────────────
# 用途：發送 digest 郵件
# 需要開啟 Gmail 2FA 並建立 App Password：
#   https://myaccount.google.com/apppasswords
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# 接收摘要郵件的地址（可與 GMAIL_USER 相同）
EMAIL_RECIPIENT=your_gmail@gmail.com

# ── Gmail OAuth Token (讀取端：Gmail API) ─────────────────────────
# 用途：透過 Gmail API 讀取 PropertyGuru/99.co 郵件 alert
# 初次設定：執行 python run.py --auth-gmail 自動產生 config/token.json
# GitHub Actions 部署時：把 config/token.json 的內容貼到此變數
# （本機開發不需要設定，token.json 會自動產生）
# GMAIL_OAUTH_TOKEN={"token":"...","refresh_token":"...","..."}

# ── OneMap.sg API (路由計算) ────────────────────────────────────
# 免費 SG 政府地圖 API，需在 https://www.onemap.gov.sg 註冊
ONEMAP_EMAIL=your_email@example.com
ONEMAP_PASSWORD=your_onemap_password

# ── 可選覆蓋設定 ────────────────────────────────────────────────
# 以下設定通常在 config/settings.yaml 設定，.env 可覆蓋
# BUDGET_MAX_SGD=3800
# EMAIL_RECIPIENT_OVERRIDE=another@email.com
